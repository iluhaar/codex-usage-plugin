{
  "name": "@illiadotdev/codex-usage-plugin",
  "version": "0.2.16",
  "license": "MIT",
  "description": "OpenCode plugin for viewing Codex ChatGPT usage limits and credits.",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iluhaar/codex-usage-plugin.git"
  },
  "homepage": "https://github.com/iluhaar/codex-usage-plugin#readme",
  "bugs": {
    "url": "https://github.com/iluhaar/codex-usage-plugin/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "codex-usage-plugin": "dist/bin/codex-usage-plugin.js"
  },
  "keywords": [
    "opencode",
    "codex",
    "plugin",
    "quota",
    "tui"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "install-plugin": "npm run build && node dist/bin/codex-usage-plugin.js --install",
    "uninstall-plugin": "node dist/bin/codex-usage-plugin.js --uninstall",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node --test test/plugin.test.mjs"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxlint": "^1.0.0",
    "typescript": "^5.9.3"
  }
}
